# ─── WSTV Seedance Dashboard — environment variables ───
# Copy this file to `.env.local` and fill in local values.
# `.env.local` is gitignored — never commit real secrets.
# Never expose secrets in frontend code.
# Never use NEXT_PUBLIC_ for API keys or other secrets.

# Prisma / SQLite database connection (required to run the app)
DATABASE_URL="file:./prisma/dev.db"

# ─── Dry-run safety defaults ───
# Real paid API calls must remain disabled unless the server-side guard is
# explicitly changed and all flags are intentionally enabled.
DRY_RUN=true
ENABLE_REAL_API=false
ALLOW_PAID_CALLS=false

# ─── BytePlus / ModelArk Seedance 2.0 (server-side only) ───
# ARK_API_KEY is server-side only. Leave empty for dry-run / planning mode.
# Never expose it in frontend code, never use NEXT_PUBLIC_, and never commit
# `.env.local` or any real key.
ARK_API_KEY=""

# Optional: override the ModelArk base URL (defaults to the AP Southeast region).
# ARK_BASE_URL="https://ark.ap-southeast.bytepluses.com"
