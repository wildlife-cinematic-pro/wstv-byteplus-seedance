# ─── WSTV Seedance Dashboard — environment variables ───
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real secrets.

# Prisma / SQLite database connection (required to run the app)
DATABASE_URL="file:./prisma/dev.db"

# ─── BytePlus / ModelArk Seedance 2.0 (server-side only) ───
# The API key (Bearer token) for real generation. Leave empty for dry-run /
# Safe Mode planning. NEVER expose this in the frontend or commit it.
ARK_API_KEY=""

# Optional: override the ModelArk base URL (defaults to the AP Southeast region).
# ARK_BASE_URL="https://ark.ap-southeast.bytepluses.com"
